{
  "manifest_version": 3,
  "name": "SalesPlay LinkedIn Extension",
  "version": "1.0.0",
    "icons": {
    "16": "/fav.png",
    "32": "/fav.png",
    "48": "/fav.png",
    "128": "/fav.png"
  },
  "description": "Reads LinkedIn profile URL and connects with SalesPlay.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "sidePanel",
    "webNavigation"
  ],
  "host_permissions": [
    "https://www.linkedin.com/in/*",
    "https://api-salesplay.marketsandmarkets.com/*"
  ],
  "action": {
    "default_title": "SalesPlay Extension"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["https://www.linkedin.com/*"]
    }
  ]
}